        if other.emotional_memory['gratitude'] > Config.EMOTIONAL_GRATITUDE_THRESHOLD:
            other_power *= (1.0 - Config.GRATITUDE_AGGRESSION_REDUCTION * (other.emotional_memory['gratitude'] - Config.EMOTIONAL_GRATITUDE_THRESHOLD))
