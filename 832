        self.history = deque(maxlen=20)
        self._line = 0

    def update(self, field, t):
        e = np.mean(field[:,:,CH['energy']])
        g = np.mean(field[:,:,CH['signal_grief']])
        b = np.mean(field[:,:,CH['binding']])
        u = np.mean(field[:,:,CH['unknown']])
