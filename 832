        normal_count = len([p for p in alive if p.role_type == "normal"])
        for p in self.patterns:
            if not p.alive or p.pending_spore is None: continue
            spore = p.pending_spore
            if not (0 <= spore['x'] < Config.WORLD_SIZE and 0 <= spore['y'] < Config.WORLD_SIZE): p.pending_spore = None; continue
            if self.field[spore['x'], spore['y'], CH['owner']] != 0: continue
            if normal_count >= Config.OVERPOPULATION_CAP: continue
            child = self.create_pattern({(spore['x'], spore['y'])}, parent=p)
            child.scar_dream = spore['scar_dream']
            p.pending_spore = None

    def resolve_competitions_spatial(self, max_dist=None):
        if max_dist is None: max_dist = Config.COMPETITION_MAX_DISTANCE
        alive = [p for p in self.patterns if p.alive and p.cells]
        if len(alive) < 2: return
        cell_size = max(1, max_dist)
        spatial_map = {}
        for p in alive:
            cx = sum(c[0] for c in p.cells) // len(p.cells)
            cy = sum(c[1] for c in p.cells) // len(p.cells)
            key = (cx // cell_size, cy // cell_size)
            spatial_map.setdefault(key, []).append(p)
        checked_pairs = set()
        for (gx, gy), group in spatial_map.items():
            for dx in [-1, 0, 1]:
                for dy in [-1, 0, 1]:
                    neighbor_key = (gx + dx, gy + dy)
                    if neighbor_key not in spatial_map: continue
                    others = spatial_map[neighbor_key]
                    for p1 in group:
                        for p2 in others:
                            if p1.id >= p2.id: continue
                            pair = (p1.id, p2.id)
                            if pair in checked_pairs: continue
                            if not p1.cells & p2.cells: continue
                            checked_pairs.add(pair)
                            p1.compete(p2, self.field)

    def detect_new_components(self, min_cells=None):
        if min_cells is None: min_cells = Config.MIN_COMPONENT_CELLS
        energy = np.nan_to_num(self.field[:,:,CH['energy']], nan=0.0)
        mask = energy > Config.PATTERN_ENERGY_THRESHOLD
        labeled, num = label(mask)
        slices = find_objects(labeled)
        components = []
        for i, slc in enumerate(slices, 1):
            if slc is None: continue
            region = labeled[slc] == i
            coords = np.argwhere(region)
            if len(coords) < min_cells: continue
            cells = {(slc[0].start + c[0], slc[1].start + c[1]) for c in coords}
            components.append(cells)
        return components

    def match_patterns(self, new_components, t=None):
        updated = []
        alive_old = [p for p in self.patterns if p.alive]
        normal_cnt = len([p for p in alive_old if p.role_type == "normal"])
        matched_ids = set()
        for cells in new_components:
            best_p, best_ov = None, 0
            for p in alive_old:
                if p.id in matched_ids: continue
                ov = len(cells & p.cells)
                if ov > best_ov:
                    best_ov, best_p = ov, p
            if best_p and best_ov > len(cells) * 0.3:
                best_p.cells = cells
                best_p.update_properties(self.field)
                updated.append(best_p)
                matched_ids.add(best_p.id)
            else:
                if normal_cnt < Config.OVERPOPULATION_CAP:
                    p = self.create_pattern(cells)
                    updated.append(p)
                    normal_cnt += 1
        for p in alive_old:
            if p.id not in matched_ids:
                updated.append(p)
        self.patterns = updated

    def step(self, t):
        self.age = t
        self._energy_injected_this_step = 0.0
        self._energy_taxed_this_step = 0.0

        self._update_sanctuary(t)
        self._rare_crisis(t)

        if t % 1618 == 0 and t > 0:
            self._saved_anti_gravity = Config.ANTI_GRAVITY_STRENGTH
            Config.ANTI_GRAVITY_STRENGTH = 2.0
        elif hasattr(self, '_saved_anti_gravity'):
            Config.ANTI_GRAVITY_STRENGTH = self._saved_anti_gravity
            del self._saved_anti_gravity

        e_before = np.sum(self.field[:,:,CH['energy']])
        self.field_dynamics(t)
        self._energy_injected_this_step += np.sum(self.field[:,:,CH['energy']]) - e_before

        e_before = np.sum(self.field[:,:,CH['energy']])
        self.layer_zero_manager.crisis_injection(self.field, t)
        self._energy_injected_this_step += np.sum(self.field[:,:,CH['energy']]) - e_before

        e_before = np.sum(self.field[:,:,CH['energy']])
        self.layer_zero_manager.apply_operator_influence(self.field, self.patterns)
        self._energy_injected_this_step += np.sum(self.field[:,:,CH['energy']]) - e_before

        e_before = np.sum(self.field[:,:,CH['energy']])
        ecosystem_pressure(self.field)
        self._energy_injected_this_step += np.sum(self.field[:,:,CH['energy']]) - e_before

        e_before = np.sum(self.field[:,:,CH['energy']])
        self.layer_zero_manager.anti_conformist_injection(self.patterns, t)
        self._energy_injected_this_step += np.sum(self.field[:,:,CH['energy']]) - e_before

        e_before = np.sum(self.field[:,:,CH['energy']])
        self.layer_zero_manager.force_diversification(self.patterns, self.field, t)
        self._energy_injected_this_step += np.sum(self.field[:,:,CH['energy']]) - e_before

        e_before = np.sum(self.field[:,:,CH['energy']])
        self.layer_zero_manager.apply_global_given_queue(self.patterns, self.field, t)
        self._energy_injected_this_step += np.sum(self.field[:,:,CH['energy']]) - e_before

        if not hasattr(self, '_sg_crisis_timer'):
            self._sg_crisis_timer = 0
            self._sg_crisis_active = False

        alive_now = [p for p in self.patterns if p.alive]
        if alive_now:
            sg_vals = [float(np.mean(np.abs(p.prediction - p.belief))) for p in alive_now]
            avg_sg = safe_mean(sg_vals, 0.5)
            if self._sg_crisis_timer > 0:
                self._sg_crisis_timer -= 1
                if self._sg_crisis_timer == 0:
                    self._sg_crisis_active = False
            else:
                if avg_sg < Config.SG_CRISIS_THRESHOLD:
                    self._sg_crisis_active = True
                    self._sg_crisis_timer = Config.SG_CRISIS_DURATION
            if self._sg_crisis_active:
                for p in alive_now:
                    noise = np.array([deterministic_noise(p.age, p.id, i+77777) for i in range(5)])
                    p.belief += noise * Config.SG_CRISIS_NOISE_STRENGTH

        self.pattern_dict = {p.id: p for p in self.patterns if p.alive}

        alive = self.patterns
        if alive:
            self.soul_weight_average = safe_mean([p.soul_weight for p in alive], 0.5)
        else:
            self.soul_weight_average = 0.5

        N = len(alive)
        if N > 85:
            if not self._antigravity_active:
                self._antigravity_active = True
                self._saved_normal_anti_gravity = Config.ANTI_GRAVITY_STRENGTH
            for p in alive:
                cells = len(p.cells)
                global_pressure = 1.0 + 0.04 * (N - 85)
                if cells <= 15:
                    size_factor = 1.0
                else:
                    size_factor = 1.0 + ((cells - 15) / 15.0) * 1.2
                p._antigravity_boost = global_pressure * size_factor
        else:
            self._antigravity_active = False
            for p in alive:
                p._antigravity_boost = 1.0

        if N < 85:
            self._art_next_strike_step = None
            self._art_over90_volley_done = False
        else:
            if not hasattr(self, '_art_next_strike_step') or self._art_next_strike_step is None:
                self._art_next_strike_step = t + Config.MARKED_INTERVAL
            if t >= self._art_next_strike_step:
                self._perform_marked_volley(t, count=15)
                self._art_next_strike_step = t + Config.MARKED_INTERVAL
                self._art_over90_volley_done = True
                if Config.VERBOSE_LOGS:
                    print(f"[t={t}] 💥 ART STRIKE! 15 dominants culled at population {N}.")

        if self._art_over90_volley_done:
            for p in alive:
                if p.role_type == "disorganizer" and p.coherence < 0.3:
                    if phi_hash(p.id, t, 12345) < 0.01:
                        p.emotional_memory['grief'] = max(0.0, p.emotional_memory.get('grief', 0) - 0.2)
                        p.energy = min(1.0, p.energy + 0.3)
                        p._log_event("antigravity_drift_used")

        if not hasattr(self, '_pop_stall_counter'):
            self._pop_stall_counter = 0
            self._pop_last = 0
            self._kiss_of_life_used = 0

        alive_now = [p for p in self.patterns if p.alive]
        N = len(alive_now)
        if N == self._pop_last:
            self._pop_stall_counter += 1
        else:
            self._pop_stall_counter = 0
        self._pop_last = N

        if self._pop_stall_counter >= 3:
            for p in alive_now:
                p.emotional_memory['gratitude'] = min(1.0, p.emotional_memory.get('gratitude', 0) + 0.05)
                p.energy = min(1.0, p.energy + 0.1)
                if phi_hash(p.id, self.age, 111) < 0.1:
                    new_concept = (np.float64(round(phi_hash(p.id, 0, 222), 1)),
                                   np.float64(round(phi_hash(p.id, 1, 333), 1)),
                                   np.float64(round(p.soul_weight, 1)),
                                   p.semantic_state)
                    if new_concept not in p.concept_graph.nodes:
                        p.concept_graph.nodes[new_concept] = {"count": 1.0, "value": np.zeros(4)}
                        p._log_event("kiss_of_life_new_idea")
            self._pop_stall_counter = 0
            self._kiss_of_life_used += 1
            if Config.VERBOSE_LOGS:
                print(f"[t={self.age}] 🌸 KISS OF LIFE: Population stalled at {N}.")

        if t % 500 == 0:
            sg_vals = [float(np.mean(np.abs(p.prediction - p.belief))) for p in self.patterns if p.alive]
            if sg_vals:
                min_sg, max_sg = min(sg_vals), max(sg_vals)
                median_sg = sorted(sg_vals)[len(sg_vals)//2]
                print(f"🌀 Spirit Gap Distribution: min={min_sg:.3f}, p50={median_sg:.3f}, max={max_sg:.3f}")

        if t < 200 and t % 10 == 0:
            for p in self.patterns:
                if p.alive and p.trust_ledger.entries:
                    for sid in p.trust_ledger.entries:
                        p.trust_ledger.entries[sid] = min(1.0, p.trust_ledger.entries[sid] + 0.05)

        all_trust_vals = []
        for p in self.patterns:
            if p.alive:
                all_trust_vals.extend(p.trust_ledger.entries.values())
        avg_trust = safe_mean(all_trust_vals, Config.TRUST_BASE) if all_trust_vals else Config.TRUST_BASE
        if avg_trust < 0.4:
            self.target_disorganizer_fraction = 0.50
        elif avg_trust < 0.7:
            self.target_disorganizer_fraction = 0.30
        else:
            self.target_disorganizer_fraction = 0.15

        alive_sg = [float(np.mean(np.abs(p.prediction - p.belief))) for p in self.patterns if p.alive]
        avg_sg = safe_mean(alive_sg, 0.5) if alive_sg else 0.5
        if avg_sg < Config.SG_TURBULENCE_THRESHOLD:
            tremor_strength = Config.GLOBAL_SPIRIT_TREMOR_BASE + \
                (Config.GLOBAL_SPIRIT_TREMOR_MAX - Config.GLOBAL_SPIRIT_TREMOR_BASE) * \
                (1.0 - avg_sg / Config.SG_TURBULENCE_THRESHOLD)
        else:
            tremor_strength = Config.GLOBAL_SPIRIT_TREMOR_BASE
        for p in self.patterns:
            if p.alive:
                shake = np.array([deterministic_noise(t, p.id, i+88888) for i in range(5)])
                p.belief += shake * tremor_strength

        given_counter = {'count': 0}
        for p in self.patterns:
            if not p.alive: continue
            p.update_model(self.field, lineage_counts=None, given_counter=given_counter, t=t,
                           witness=self.witness)
            p.grow(self.field)

        self.resolve_competitions_spatial()

        current_hunger = self.compute_hunger_multiplier()
        for p in self.patterns:
            if p.alive:
                boost = getattr(p, '_antigravity_boost', 1.0)
                p.metabolic_tax(self.field, current_hunger * boost)
                self._energy_taxed_this_step += getattr(p, '_last_metabolic_taken', 0.0)
        for p in self.patterns:
            if p.alive and p.should_die():
                p.alive = False
                self.echo_system.store(p)

        for p in self.patterns:
            if not p.alive or p.role_type != "normal": continue
            fold_count = p.event_counts.get('fold', 0)
            if fold_count >= 1:
                disorganizer_cnt = len([pp for pp in self.patterns if pp.alive and pp.role_type == "disorganizer"])
                alive_total = len([pp for pp in self.patterns if pp.alive])
                current_frac = disorganizer_cnt / max(1, alive_total)
                if current_frac >= self.target_disorganizer_fraction:
                    continue
                if fold_count >= Config.FOLDS_FOR_DEEP_FALL:
                    prob = 1.0
                    soul_target = Config.DEEP_FALL_SOUL_PENALTY
                    redemption_delay = Config.DEEP_FALL_REDEMPTION_DELAY
                    fall_type = "fallen"
                else:
                    prob = Config.QUICK_FALL_PROB
                    soul_target = Config.FORCED_SOUL_COLLAPSE_VALUE
                    redemption_delay = Config.REDEMPTION_ARC_STEP_DELAY
                    fall_type = "broken"
                if phi_hash(p.id, t, 777) < prob:
                    p.role_type = "disorganizer"
                    p.emotional_memory['gratitude'] = 0.1
                    p.emotional_memory['grief'] = 0.8
                    p.semantic_state = "exploring_danger"
                    p.intent = {"type": "explore", "priority": 2.0, "age": 0, "persistence": 9999}
                    p.intent_commitment = 2.0
                    p.disorganizer_age_at_birth = p.age
                    p.redemption_timer = redemption_delay
                    p._deterministic_redemption_triggered = False
                    p._forced_soul_collapse_done = False
                    p._redemption_arc_step = 0
                    p._steps_since_trigger = 0
                    p.soul_weight = min(p.soul_weight, soul_target)
                    p._log_event(f"became_disorganizer_{fall_type}", folds=fold_count)
                    self.witness.record(p.id, f"became_disorganizer_{fall_type}", folds=fold_count)
                    if fall_type == "fallen":
                        self.witness.record(p.id, "deep_fallen_birth", folds=fold_count, soul=p.soul_weight)

        for p in self.patterns:
            if not p.alive or p.role_type == "disorganizer" or p.quarantine_timer > 0: continue
            sig = SemanticSignal(channel=CH['signal_gratitude'], strength=Config.TRUST_SIGNAL_STRENGTH,
                                 sender_id=p.id, sender_context=p.semantic_state,
                                 sender_arc=p.arc_tracker.active_arc, sender_age=p.age,
                                 sender_concept_wisdom=p.arc_tracker.get_wisdom_weight(),
                                 sender_lineage=p.lineage_id, _sender_concept_graph=p.concept_graph)
            for (x, y) in p.cells:
                for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                    nx, ny = (x+dx)%Config.WORLD_SIZE, (y+dy)%Config.WORLD_SIZE
                    owner = self.field[nx, ny, CH['owner']]
                    if owner != 0 and owner != p.id and owner in self.pattern_dict:
                        target = self.pattern_dict[owner]
                        if target.role_type != "disorganizer" and target.quarantine_timer == 0:
                            target._incoming_signals.append(sig)

        for p in self.patterns:
            if not p.alive or p.role_type != "disorganizer": continue
            for (x, y) in p.cells:
                for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                    nx, ny = (x+dx)%Config.WORLD_SIZE, (y+dy)%Config.WORLD_SIZE
                    owner = self.field[nx, ny, CH['owner']]
                    if owner != 0 and owner != p.id and owner in self.pattern_dict:
                        neighbor = self.pattern_dict[owner]
                        if neighbor.role_type == "normal":
                            neighbor.emotional_memory['grief'] = float(np.clip(
                                neighbor.emotional_memory['grief'] + Config.DISORGANIZER_GRIEF_AURA,
                                0.0, Config.MAX_GRIEF_SIGNAL))

        alive_count = len([p for p in self.patterns if p.alive])
        for p in self.patterns:
            if alive_count >= Config.OVERPOPULATION_CAP:
                break
            if p.alive and p.can_divide():
                child, new_id = p.divide(self.field, self.next_id)
                if child:
                    self.next_id = new_id
                    self.patterns.append(child)
                    self.pattern_dict[child.id] = child
                    alive_count += 1

        self.patterns = [p for p in self.patterns if p.alive]

        SAFE_SIZE_THRESHOLD = 15
        POP_HARD_CAP = 85
        alive = [p for p in self.patterns if p.alive]
        N_after = len(alive)
        if N_after > POP_HARD_CAP:
            def dominance(p):
                cells = len(p.cells)
                if cells <= SAFE_SIZE_THRESHOLD:
                    cell_score = cells
                else:
                    cell_score = SAFE_SIZE_THRESHOLD + (cells - SAFE_SIZE_THRESHOLD) * 2.5
                return (cell_score * 0.7 + p.soul_weight * 0.15 +
                        safe_mean(list(p.trust_ledger.entries.values()), 0.5) * 0.1 +
                        p.emotional_memory['gratitude'] * 0.05)
            ranked = sorted(alive, key=lambda p: (dominance(p), p.id), reverse=True)
            to_cull = N_after - POP_HARD_CAP
            for p in ranked[:to_cull]:
                p.alive = False
                p._log_event("hubris_fall", dominance=round(dominance(p),3),
                             cells=len(p.cells), reason="territorial_overload")
                self.echo_system.store(p)
                for (x,y) in p.cells:
                    self.field[x,y,CH['owner']] = 0
            self.patterns = [p for p in self.patterns if p.alive]
            if Config.VERBOSE_LOGS:
                max_cells = max(len(p.cells) for p in ranked[:to_cull]) if to_cull else 0
                print(f"[t={t}] 📉 HUBRIS FALL: {to_cull} dominants culled (max_cells={max_cells}) → N={POP_HARD_CAP}")

        self.field[:,:,CH['energy']] = np.clip(self.field[:,:,CH['energy']], -0.2, 0.8)

        for p in self.patterns:
            if p.alive:
                self.echo_system.field_whisper(p, self.field, t)

        alive = [p for p in self.patterns if p.alive]
        if alive:
            avg_concepts = sum(len(p.concept_graph.nodes) for p in alive) / len(alive)
            for p in alive:
                if len(p.concept_graph.nodes) > 1.8 * avg_concepts and len(p.concept_graph.nodes) > 15:
                    if not hasattr(p, '_mutant_saved'):
                        self.echo_system.store_anomaly(p, "mutant")
                        p._mutant_saved = True
                        self.witness.record(p.id, "mutant_detected", concepts=len(p.concept_graph.nodes))

        alive = [p for p in self.patterns if p.alive]
        for p in alive:
            intent_switches = sum(1 for ev in p.biography[-50:] if ev.get('type') == 'intent_switch')
            if intent_switches > 15 and p.age > 200:
                if not hasattr(p, '_autonomous_saved'):
                    self.echo_system.store_anomaly(p, "autonomous_entity")
                    p._autonomous_saved = True
                    self.witness.record(p.id, "autonomous_entity_detected", switches=intent_switches)

        autonomous_detected = sum(1 for p in alive if hasattr(p, '_autonomous_saved'))
        redeemed_cnt = sum(1 for p in alive if hasattr(p, 'redemption_complete') and p.redemption_complete)
        fold_count = sum(p.event_counts.get('fold', 0) for p in alive)
        disorg_cnt = sum(1 for p in alive if p.role_type == "disorganizer")
        event_signature = (autonomous_detected, redeemed_cnt, fold_count, disorg_cnt)
        new_hash = int(phi_hash(t, hash(event_signature), 99999) * 1000)
        self.system_entropy = int(0.85 * self.system_entropy + 0.15 * new_hash)

        if t % 1000 == 0 and t > 0:
            alive = [p for p in self.patterns if p.alive]
            count_leap = min(15, len(alive))
            for i in range(count_leap):
                chosen = alive[int(phi_hash(t, i, 9999) * len(alive)) % len(alive)]
                saved_soul = chosen.soul_weight
                saved_body = chosen.body_memory
                saved_contra = chosen.unresolved_contradiction
                saved_emotions = dict(chosen.emotional_memory)
                saved_trust = dict(chosen.trust_ledger.entries)
                chosen.model = np.array([phi_hash(chosen.id, i, 77777) - 0.5 for _ in range(5)]) * 0.3
                chosen.belief = np.array([phi_hash(chosen.id, i, 88888) - 0.5 for _ in range(5)]) * 0.3
                chosen.prediction = chosen.belief + chosen.model
                chosen.pred_error = Config.MIN_ACTIVE
                chosen.coherence = 0.5
                chosen.self_consistency = 0.5
                chosen.soul_weight = saved_soul
                chosen.body_memory = saved_body
                chosen.unresolved_contradiction = saved_contra
                chosen.emotional_memory = saved_emotions
                chosen.trust_ledger.entries = saved_trust
                chosen._log_event("quantum_leap")
                if Config.VERBOSE_LOGS and i == 0:
                    print(f"[t={t}] ⚛️ QUANTUM LEAP: 15 agents receive new visions!")

            disorganizers = [p for p in self.patterns if p.alive and p.role_type == "disorganizer"]
            count_call = min(5, len(disorganizers))
            for i in range(count_call):
                chosen = disorganizers[int(phi_hash(t, i, 11111) * len(disorganizers)) % len(disorganizers)]
                if chosen._redemption_arc_step == 1:
                    chosen.emotional_memory['grief'] = max(0.0, chosen.emotional_memory['grief'] - 0.1)
                    chosen.emotional_memory['gratitude'] = min(1.0, chosen.emotional_memory['gratitude'] + 0.1)
                    chosen._log_event("ancestral_call")
            if Config.VERBOSE_LOGS and count_call > 0:
                print(f"[t={t}] 🕊️ ANCESTRAL CALL: {count_call} disorganizers hear the whispers.")

        e_before = np.sum(self.field[:,:,CH['energy']])
        self.emergency_rescue(t)
        self._energy_injected_this_step += np.sum(self.field[:,:,CH['energy']]) - e_before

        e_before = np.sum(self.field[:,:,CH['energy']])
        self.spawn_unknown_patterns(t)
        self._energy_injected_this_step += np.sum(self.field[:,:,CH['energy']]) - e_before

        e_before = np.sum(self.field[:,:,CH['energy']])
        self.process_spores()
        self._energy_injected_this_step += np.sum(self.field[:,:,CH['energy']]) - e_before

        for p in self.patterns: p.age += 1

        if t % 1000 == 0 and self.echo_system.pantheon:
            for p in self.patterns:
                if p.alive and p.age < 50:
                    idx = int(phi_hash(t, p.id, 777) * len(self.echo_system.pantheon)) % len(self.echo_system.pantheon)
                    entry = self.echo_system.pantheon[idx]
                    concept_key = entry.get('concept_graph_sample', [None])[0]
                    if concept_key and concept_key not in p.concept_graph.nodes:
                        p.concept_graph.nodes[concept_key] = {"count": 1.0, "value": np.zeros(4)}
                        p._log_event("pantheon_radiation")

        for p in self.patterns:
            if not p.alive:
                continue
            if not hasattr(p, 'self_phenomenal_prediction'):
                p.self_phenomenal_prediction = 0.5
