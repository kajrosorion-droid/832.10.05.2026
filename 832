import numpy as np
from collections import defaultdict, deque, Counter

# =========================
# Вспомогательные функции (должны быть определены до классов)
# =========================
def safe_mean(arr, default=0.0):
    """Безопасное среднее: работает со списками и numpy-массивами, игнорирует NaN."""
    if isinstance(arr, np.ndarray):
        # Для numpy массивов используем встроенные методы
        mask = np.isfinite(arr)
        if np.any(mask):
            return float(np.mean(arr[mask]))
        else:
            return default
    else:
        # Для списков и других итерируемых объектов
        arr_clean = [x for x in arr if not np.isnan(x) and np.isfinite(x)]
        return np.mean(arr_clean) if arr_clean else default

def phi_hash(*args, mod=2**32):
    """Псевдослучайный хеш для детерминированных вероятностей."""
    h = 0
    for a in args:
        h = (h * 1315423911 + hash(a)) & 0x7fffffff
    return (h % mod) / mod

def calculate_boredom(patterns, field):
    """Вычисляет уровень скуки системы на основе ошибок предсказаний, unknown и когнитивного напряжения."""
    if not patterns: return 0.0
    err_history = []
    for p in patterns:
        if p.alive and hasattr(p, 'pred_error_history') and p.pred_error_history:
            err_history.extend(p.pred_error_history[-Config.BOREDOM_WINDOW:])
    if not err_history: return 0.0
    avg_recent_err = np.mean(err_history)
    avg_unknown = safe_mean(field[:,:,CH['unknown']], 0.1)
    avg_tension = safe_mean([p.cognitive_tension for p in patterns if p.alive], 0.01)
    score = 0.0
    if avg_recent_err < Config.BOREDOM_ERR_THRESHOLD: score += 0.4
    if avg_unknown < Config.BOREDOM_UNKNOWN_THRESHOLD: score += 0.4
    if avg_tension < Config.BOREDOM_TENSION_THRESHOLD: score += 0.2
    return score

def ecosystem_pressure(field):
    """Выравнивает энергию поля через диффузию и создаёт потоки."""
    energy = np.nan_to_num(field[:,:,CH['energy']], nan=0.0)
    avg = np.mean(energy)
    field[:,:,CH['energy']] += 0.002 * (avg - energy)
    field[:,:,CH['flux']] += 0.001 * (np.roll(energy, 1, axis=0) - energy) + 0.001 * (np.roll(energy, -1, axis=1) - energy)
    return field

class FieldVoice:
    """Голос поля – наблюдает за состоянием и генерирует ритмические фразы."""
    def __init__(self):
