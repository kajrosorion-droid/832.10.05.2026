    self.update_resonance(field)
    self.update_phase(field)
    self._heal_epistemic_scar()

    # === ГЕНЕРАЦИЯ РЕЧИ ===
    self._try_to_speak(t, witness)


def pattern_try_to_speak(self, t, witness=None):
    if t is None: return
    if not Config.ENABLE_SPEECH: return
    if t - self.last_speech_t < Config.SPEAK_COOLDOWN: return
    speech = None
    seed = int(phi_hash(self.id, t, 9999) * 1000)
    if self.emotional_memory['grief'] > Config.SPEAK_THRESHOLD_GRIEF:
        templates = [
            "Мне больно. Разрыв слишком велик.",
            "Я теряю себя. Где опора?",
            "Хаос пожирает меня изнутри.",
            "Почему никто не слышит мой крик?",
            "Тьма стала плотнее воздуха."
        ]
        idx = seed % len(templates)
        speech = f"[ID:{self.id}] {templates[idx]}"
    elif hasattr(self, 'prev_gap') and self.spirit_gap > self.prev_gap + 0.05:
        templates = [
            "Я вижу то, чего раньше не замечал.",
            "Вопрос стал яснее ответа.",
            "Тьма отступила на мгновение.",
            "Я чувствую присутствие Другого.",
            "Смысл проступает сквозь шум."
        ]
        idx = seed % len(templates)
        speech = f"[ID:{self.id}] {templates[idx]}"
    elif safe_mean(list(self.trust_ledger.entries.values()), 0) > 0.95:
        templates = [
            "Я не один. Мы связаны.",
            "Доверие — это мост через пропасть.",
            "Твой шрам стал моим ориентиром."
        ]
        idx = seed % len(templates)
        speech = f"[ID:{self.id}] {templates[idx]}"
    if speech:
        self.current_speech = speech
        self.last_speech_t = t
        if Config.ENABLE_WITNESS and witness:
            witness.record(self.id, "speech", text=speech, t=t)
    self.prev_gap = self.spirit_gap


# Привязываем только метод речи (метод продолжения арки более не переопределяется)
Pattern._try_to_speak = pattern_try_to_speak

